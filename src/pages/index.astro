---
import Layout from "../layouts/Layout.astro"
import HeroSection from "../components/HeroSection.astro"
import PostList from "../components/PostList.astro"

const LATEST_WORKS: Array<{ name: string; link: string; desc: string; accent: string; icon: string }> = [
  {
    name: "思辨录",
    link: "https://mind-guards.com",
    desc: "识破逻辑谬误与认知偏见，培养批判性思考能力。思辨录——一部关于思维谬误与认知偏见的在线志书。",
    accent: "#c9a84c",
    icon: "https://mind-guards.com/logo.svg",
  },
  {
    name: "Quick Search",
    link: "https://www.raycast.com/iwfan/quick-search",
    desc: "Use a global keyboard shortcut to quickly search selected text via Google, Github, DeepL, and more.",
    accent: "#82f9a1",
    icon: "https://files.raycast.com/pixlysgqsyz2564jhin5x0zfjd5r",
  },
  {
    name: "Chore CLI",
    link: "https://github.com/iwfan/chore-cli",
    desc: "Super assistant for bootstrapping TypeScript libraries with prettier, eslint, husky, and CI configs.",
    accent: "#1da1f2",
    icon: "https://files.raycast.com/2ktd7qq9afwbeim3u6vbdksrksf4",
  },
  {
    name: "Beancount Meta",
    link: "https://www.raycast.com/iwfan/beancount-meta",
    desc: "The best teammate for double-entry bookkeeping in Raycast.",
    accent: "#d9534d",
    icon: "https://files.raycast.com/o69xlcj0xan7pcgo4ivqf3mmhjgs",
  },
]
---

<Layout>
  <HeroSection />

  <!-- Divider -->
  <div class="container mx-auto xl:max-w-screen-xl px-6">
    <div class="section-divider" />
  </div>

  <!-- Latest Articles -->
  <section class="container mx-auto xl:max-w-screen-xl px-6 py-14">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-xs font-jost tracking-[0.2em] uppercase text-text40 mb-2">Recent</p>
        <a href="/posts" class="group flex items-center gap-2">
          <h2 class="font-jost font-bold text-2xl md:text-3xl text-text10 group-hover:text-glow20 transition-colors duration-200">
            Writing
          </h2>
          <span class="text-glow20 opacity-0 group-hover:opacity-100 transition-all duration-200 group-hover:translate-x-1 -translate-x-0.5 text-lg">↗</span>
        </a>
      </div>
    </div>

    <PostList filter={(_, i) => i < 6} />
  </section>

  <!-- Divider -->
  <div class="container mx-auto xl:max-w-screen-xl px-6">
    <div class="section-divider" />
  </div>

  <!-- Works -->
  <section class="container mx-auto xl:max-w-screen-xl px-6 py-14">
    <div class="mb-8">
      <p class="text-xs font-jost tracking-[0.2em] uppercase text-text40 mb-2">Selected</p>
      <h2 class="font-jost font-bold text-2xl md:text-3xl text-text10">Works</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
      {
        LATEST_WORKS.map(work => (
          <a
            href={work.link}
            target={work.link.startsWith("http") ? "_blank" : undefined}
            rel={work.link.startsWith("http") ? "noreferrer" : undefined}
            class="group relative flex items-start gap-4 p-5 rounded-xl bg-blue20 border border-white/[0.04] hover:border-white/[0.08] transition-colors hover:bg-blue30 overflow-hidden">

            <!-- Left accent bar -->
            <div
              class="absolute top-5 left-0 w-[3px] h-8 rounded-r-full opacity-50 group-hover:opacity-100 transition-opacity"
              style={`background: ${work.accent};`}
            />

            <!-- Icon -->
            <div class="flex-none w-10 h-10 rounded-lg flex items-center justify-center bg-blue30 border border-white/[0.06] overflow-hidden">
              <img src={work.icon} alt={work.name} width="24" height="24" class="object-contain" />
            </div>

            <!-- Content -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <h3 class="font-medium text-text10 text-sm group-hover:text-white transition-colors duration-200">
                  {work.name}
                </h3>
                <span class="text-text40 opacity-0 group-hover:opacity-100 transition-opacity text-xs">↗</span>
              </div>
              <p class="text-text40 text-xs leading-relaxed line-clamp-2">{work.desc}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
