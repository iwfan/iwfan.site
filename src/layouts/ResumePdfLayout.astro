---
import Head from "./Head.astro"
import "../styles/resume-pdf.css"

interface Props {
  title?: string
  desc?: string
}

const { title, desc } = Astro.props
---

<!doctype html>
<html lang="zh-CN">
  <Head title={title} description={desc}>
    <meta name="robots" content="noindex,nofollow" />
  </Head>
  <body class="resume-pdf-body">
    <main class="resume-pdf-page">
      <article class="resume-pdf-content">
        <slot />
      </article>
    </main>
  </body>
</html>
