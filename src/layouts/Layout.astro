---
import Head from "./Head.astro"
import { author_email, site_title } from "../site.config"
import "../styles/global.css"

interface Props {
  title?: string
  desc?: string
  classes?: string[]
}

const { title, desc, classes } = Astro.props
const { pathname } = Astro.url

const isActive = (href: string) => href === pathname || href === pathname.replace(/\/$/, "")
---

<!doctype html>
<html lang="en">
  <Head title={title} description={desc} />
  <body>
    <header>
      <div class="flex items-center justify-between container mx-auto px-4 py-8">
        <a href="/" title={site_title}>
          <img src="/favicon.svg" alt={site_title} width="36" height="36" />
        </a>
        <nav class="space-x-2 text-text30 font-medium">
          <a
            href="/posts"
            class:list={[
              "inline-block transition hover:text-glow20 u-underline",
              { "text-glow20 u-underline-active": isActive("/posts") },
            ]}>
            Blog
          </a>
          <a
            href="/about"
            class:list={[
              "inline-block transition hover:text-glow20 u-underline",
              { "text-glow20 u-underline-active": isActive("/about") },
            ]}>
            About
          </a>
        </nav>
      </div>
    </header>

    <main style="min-height: calc(100vh - 200px);" class:list={classes}>
      <slot />
    </main>

    <footer class="mt-32 border-t border-white/[0.04]">
      <div class="container mx-auto px-6 py-10">
        <div class="flex items-center justify-center gap-4">
          <div class="section-divider flex-1 max-w-24" />
          <p class="text-xs flex items-center gap-2 text-text40 font-mono tracking-wider">
            <a href="/" title={site_title} class="hover:text-glow20 transition-colors">
              <img src="/flames/colored-flame.svg" alt={site_title} width="12" height="12" class="inline" />
            </a>
            <span>©<time>{new Date().getFullYear()}</time></span>
            <a class="hover:text-glow20 transition-colors" href={`mailto:${author_email}`}>
              iwfan
            </a>
            <span class="opacity-30">·</span>
            <a
              class="hover:text-glow20 transition-colors opacity-60 hover:opacity-100"
              target="_blank"
              title="Attribution 4.0 International"
              href="https://creativecommons.org/licenses/by/4.0/"
              rel="noreferrer">
              CC BY 4.0
            </a>
          </p>
          <div class="section-divider flex-1 max-w-24" />
        </div>
      </div>
    </footer>
  </body>
</html>
