---
import Head from "../../layouts/Head.astro"

const profile = {
  siteLabel: "iwfan.resume",
  name: "Ivan (Fan Wang)",
  headline: "Front-end Engineer",
  email: "iwfan@duck.com",
  website: "https://iwfan.site",
  websiteLabel: "iwfan.site",
  github: "https://github.com/iwfan",
  githubLabel: "github.com/iwfan",
  telegram: "https://t.me/iwfan",
  telegramLabel: "t.me/iwfan",
  location: "Xi'an, China",
}

const about =
  "I have 10+ years of full-time software development experience across modern web applications and cross-platform product development. My work has spanned product-facing UI, frontend architecture, engineering infrastructure, and complex business workflows, with a focus on building maintainable systems that scale with both product scope and team size."

const highlights = [
  "Strong in architecture design, performance optimization, and turning complex product requirements into reliable, maintainable implementations.",
  "Consistently focused on code quality, meaningful testing, and engineering practices that improve long-term maintainability.",
  "Prefer a terminal-first, mouseless development workflow, and feel most productive with tools like Neovim and Lazygit.",
  "Work effectively across product, design, and engineering teams, and keep delivery quality high in fast-moving environments.",
]

const experiences = [
  {
    role: "Front-end Engineer",
    company: "Web3 Exchange",
    period: "Sep 2024 — Apr 2026",
    desc:
      "Worked on both Dex Wallet App and Telegram Wallet Mini App across Flutter and React / Next.js. Owned the contract trading module end to end, integrated multiple trading platforms, and improved transaction flow reliability, interaction quality, and client-side maintainability for on-chain trading scenarios.",
    tags: ["Flutter", "Dart", "Riverpod", "React", "Next.js", "Telegram WebApp"],
  },
  {
    role: "Front-end Engineer",
    company: "Jinshuju",
    period: "Jun 2021 — Aug 2024",
    desc:
      "Led and delivered several core products including AI Examination, Portal, and the editor/data page rebuild. Drove frontend architecture, permission system design, reusable form abstractions, and product incubation from 0 to 1, while helping improve team delivery quality, maintainability, and development efficiency.",
    tags: ["React", "Next.js", "Redux", "GraphQL", "Vitest", "AG-Grid"],
  },
  {
    role: "Front-end Engineer",
    company: "ThoughtWorks",
    period: "Mar 2019 — Jun 2021",
    desc:
      "Built core capabilities for a large-scale micro-frontend transformation and Widget SDK projects, including app registration and loading, style isolation, cross-app communication, and SDK communication protocols. Also contributed to delivery standards, framework consistency, testing, and developer documentation across multiple teams.",
    tags: ["TypeScript", "Angular", "Single-Spa", "Qiankun", "Jest", "Cypress"],
  },
  {
    role: "Java Developer",
    company: "BNC Technologies",
    period: "Jun 2016 — Mar 2019",
    desc:
      "Owned delivery of device management capabilities in the GiNMS project and led the introduction of Vue + iView to modernize frontend development. Helped complete frontend-backend separation, improved documentation workflows, and significantly increased overall development efficiency.",
    tags: ["Vue", "iView", "Webpack", "Java", "Spring", "MySQL"],
  },
]

const projects = [
  {
    name: "Mind Guards",
    href: "https://mind-guards.com/",
    linkLabel: "→ mind-guards.com",
    desc:
      "An online knowledge project about logical fallacies and cognitive biases, designed to help readers recognize flawed reasoning and build stronger critical thinking habits.",
  },
  {
    name: "Raycast Quick Search",
    href: "https://www.raycast.com/iwfan/quick-search",
    linkLabel: "→ Raycast Store",
    desc:
      "A Raycast extension that searches selected text or clipboard content through global shortcuts. It was featured by Raycast officially and has reached 3K+ installs in the Raycast Store.",
  },
  {
    name: "Chore-CLI",
    href: "https://github.com/iwfan/chore-cli",
    linkLabel: "→ GitHub",
    desc:
      "A TypeScript + Node.js CLI for scaffolding frontend projects and infrastructure. It was featured in Tech Enthusiasts Weekly and has received 100+ GitHub stars.",
  },
]

const skillGroups = [
  {
    name: "Frameworks",
    items: ["React / Next.js", "Astro / Hono", "Vue / Vite", "Redux / React Query", "Flutter"],
  },
  {
    name: "Testing",
    items: ["Jest", "Vitest", "Cypress", "React Testing Library", "Integration Testing"],
  },
  {
    name: "Engineering",
    items: ["TypeScript", "GraphQL", "Webpack", "Tailwind CSS", "Node.js"],
  },
  {
    name: "DevOps",
    items: ["Docker", "GitHub Actions", "GitLab CI", "Jenkins", "Cloudflare / Sentry"],
  },
]

const education = [
  {
    degree: "Applied Electronic Technology",
    school: "Taiyuan University · Department of Computer Engineering",
    period: "Sep 2013 — Jun 2016",
  },
]
---

<!DOCTYPE html>
<html lang="en">
  <Head title="Fan Wang Resume" description="Fan Wang English resume PDF page">
    <meta name="robots" content="noindex,nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg: #f7f5f0;
        --fg: #1a1814;
        --muted: #8a8070;
        --accent: #c84b2f;
        --rule: #ddd8ce;
        --card: #efecea;
        --font-serif: "EB Garamond", Georgia, serif;
        --font-mono: "DM Mono", "Courier New", monospace;
      }
      html { font-size: 16px; scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-serif);
        font-size: 1.05rem;
        line-height: 1.75;
        min-height: 100vh;
      }
      .page-wrap {
        max-width: 780px;
        margin: 0 auto;
        padding: 3rem 2rem 5rem;
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.75rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--rule);
      }
      .topbar-left {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 300;
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .btn-pdf {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--fg);
        background: transparent;
        border: 1px solid var(--fg);
        padding: 0.45em 1.1em;
        cursor: pointer;
        transition: background 0.18s, color 0.18s;
        text-decoration: none;
        display: inline-block;
      }
      .btn-pdf:hover { background: var(--fg); color: var(--bg); }
      .identity { margin-bottom: 2.25rem; }
      .name {
        font-family: var(--font-serif);
        font-size: 3.2rem;
        font-weight: 400;
        line-height: 1.1;
        letter-spacing: -0.01em;
        margin-bottom: 0.35rem;
      }
      .headline {
        font-size: 1.05rem;
        color: var(--muted);
        font-style: italic;
        margin-bottom: 0.8rem;
      }
      .contact-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 1.6rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 300;
        color: var(--muted);
      }
      .contact-row a {
        color: var(--muted);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: color 0.15s, border-color 0.15s;
      }
      .contact-row a:hover { color: var(--accent); border-color: var(--accent); }
      section { margin-bottom: 2.1rem; }
      .section-label {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 400;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.9rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--rule);
      }
      .about-text {
        font-size: 1.02rem;
        line-height: 1.65;
        max-width: 640px;
        color: #3a3530;
      }
      .about-points {
        margin-top: 0.65rem;
        list-style: none;
      }
      .about-points li {
        color: #4a4540;
        padding: 0.08rem 0;
      }
      .about-points li::before {
        content: "—";
        margin-right: 0.55em;
        color: var(--accent);
      }
      .exp-item {
        display: grid;
        grid-template-columns: 1fr auto;
        grid-template-rows: auto auto;
        gap: 0 2rem;
        margin-bottom: 1.45rem;
        padding-bottom: 1.45rem;
        border-bottom: 1px solid var(--rule);
      }
      .exp-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
      .exp-role {
        font-size: 1.05rem;
        font-weight: 500;
        line-height: 1.3;
      }
      .exp-company {
        font-size: 1.05rem;
        font-style: italic;
        color: var(--muted);
      }
      .exp-period {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 300;
        color: var(--muted);
        text-align: right;
        white-space: nowrap;
        padding-top: 0.25rem;
      }
      .exp-desc {
        grid-column: 1 / -1;
        margin-top: 0.45rem;
        font-size: 0.92rem;
        color: #4a4540;
        line-height: 1.58;
        max-width: 580px;
      }
      .exp-tags {
        grid-column: 1 / -1;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.55rem;
      }
      .tag {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 300;
        letter-spacing: 0.06em;
        padding: 0.18em 0.55em;
        background: var(--card);
        border: 1px solid var(--rule);
        color: var(--muted);
      }
      .project-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.3rem 2rem;
        margin-bottom: 1.2rem;
        padding-bottom: 1.2rem;
        border-bottom: 1px solid var(--rule);
      }
      .project-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
      .project-name {
        font-size: 1rem;
        font-weight: 500;
      }
      .project-name a {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px solid var(--rule);
        transition: border-color 0.15s, color 0.15s;
      }
      .project-name a:hover { color: var(--accent); border-color: var(--accent); }
      .project-link {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 300;
        color: var(--muted);
        text-decoration: none;
        white-space: nowrap;
        padding-top: 0.3rem;
        border-bottom: 1px solid transparent;
        transition: color 0.15s, border-color 0.15s;
      }
      .project-link:hover { color: var(--accent); border-color: var(--accent); }
      .project-desc {
        grid-column: 1 / -1;
        font-size: 0.9rem;
        color: #4a4540;
        line-height: 1.55;
        max-width: 560px;
      }
      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 0.8rem 1.4rem;
      }
      .skill-group-name {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 400;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.3rem;
      }
      .skill-list { list-style: none; }
      .skill-list li {
        font-size: 0.88rem;
        padding: 0.05rem 0;
        color: #3a3530;
      }
      .skill-list li::before {
        content: "—";
        margin-right: 0.5em;
        color: var(--rule);
      }
      .edu-item {
        display: grid;
        grid-template-columns: 1fr auto;
        margin-bottom: 1rem;
      }
      .edu-item:last-child { margin-bottom: 0; }
      .edu-degree { font-size: 1rem; font-weight: 500; }
      .edu-school { font-size: 0.97rem; font-style: italic; color: var(--muted); margin-top: 0.1rem; }
      .edu-period {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 300;
        color: var(--muted);
        text-align: right;
        padding-top: 0.25rem;
      }
      .footer {
        margin-top: 3rem;
        padding-top: 1rem;
        border-top: 1px solid var(--rule);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 300;
        color: var(--muted);
        display: flex;
        justify-content: space-between;
      }
      @media print {
        @page { margin: 1.15cm 1.35cm; size: A4; }
        body { background: #fff; font-size: 9.4pt; }
        .topbar { display: none; }
        .page-wrap { max-width: 100%; padding: 0; }
        .name { font-size: 24pt; }
        .headline { font-size: 0.98rem; margin-bottom: 0.65rem; }
        .contact-row { font-size: 0.68rem; gap: 0.2rem 1rem; }
        .section-label { margin-bottom: 0.65rem; }
        .about-text { font-size: 0.94rem; line-height: 1.52; }
        .about-points { margin-top: 0.45rem; }
        .about-points li { padding: 0.02rem 0; }
        .exp-item { margin-bottom: 1rem; padding-bottom: 1rem; }
        .exp-desc, .project-desc { line-height: 1.45; }
        .exp-tags { margin-top: 0.4rem; gap: 0.25rem; }
        .tag { font-size: 0.58rem; padding: 0.14em 0.45em; }
        .project-item { margin-bottom: 0.95rem; padding-bottom: 0.95rem; }
        .skills-grid { gap: 0.55rem 1rem; }
        .skill-list li { font-size: 0.82rem; }
        a { color: inherit !important; }
        section {
          break-inside: auto;
          margin-bottom: 1.35rem;
        }
        .section-label {
          break-after: avoid;
        }
        .exp-item, .project-item, .edu-item {
          break-inside: avoid;
          page-break-inside: avoid;
        }
        .exp-desc, .project-desc, .about-text, .about-points {
          break-inside: auto;
        }
        .footer { display: none; }
      }
      @media (max-width: 640px) {
        .page-wrap { padding: 2rem 1.2rem 4rem; }
        .topbar { margin-bottom: 2.5rem; }
        .name { font-size: 2.35rem; }
        .exp-item,
        .project-item,
        .edu-item {
          grid-template-columns: 1fr;
          gap: 0.4rem;
        }
        .exp-period,
        .edu-period { text-align: left; padding-top: 0; }
      }
    </style>
  </Head>
  <body>
    <div class="page-wrap">
      <header class="identity">
        <h1 class="name">{profile.name}</h1>
        <p class="headline">{profile.headline}</p>
        <div class="contact-row">
          <a href={`mailto:${profile.email}`}>{profile.email}</a>
          <span>·</span>
          <a href={profile.website} target="_blank" rel="noreferrer">{profile.websiteLabel}</a>
          <span>·</span>
          <a href={profile.github} target="_blank" rel="noreferrer">{profile.githubLabel}</a>
        </div>
      </header>

      <section>
        <div class="section-label">About</div>
        <p class="about-text">{about}</p>
        <ul class="about-points">
          {highlights.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section>
        <div class="section-label">Experience</div>
        {experiences.map((item) => (
          <div class="exp-item">
            <div>
              <div class="exp-role">{item.role}</div>
              <div class="exp-company">{item.company}</div>
            </div>
            <div class="exp-period">{item.period}</div>
            <p class="exp-desc">{item.desc}</p>
            <div class="exp-tags">
              {item.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
        ))}
      </section>

      <section>
        <div class="section-label">Selected Projects</div>
        {projects.map((project) => (
          <div class="project-item">
            <div class="project-name"><a href={project.href}>{project.name}</a></div>
            <a class="project-link" href={project.href} target="_blank" rel="noreferrer">{project.linkLabel}</a>
            <p class="project-desc">{project.desc}</p>
          </div>
        ))}
      </section>

      <section>
        <div class="section-label">Skills</div>
        <div class="skills-grid">
          {skillGroups.map((group) => (
            <div>
              <div class="skill-group-name">{group.name}</div>
              <ul class="skill-list">
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section>
        <div class="section-label">Education</div>
        {education.map((item) => (
          <div class="edu-item">
            <div>
              <div class="edu-degree">{item.degree}</div>
              <div class="edu-school">{item.school}</div>
            </div>
            <div class="edu-period">{item.period}</div>
          </div>
        ))}
      </section>
    </div>
  </body>
</html>
